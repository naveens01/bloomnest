# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/bloomnest
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Razorpay Configuration (Test Mode)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio Configuration (Optional - for OTP authentication)
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Optional - for welcome emails and notifications)
# For Gmail: Use App Password (not regular password)
# Enable 2FA and generate App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=BloomNest <noreply@bloomnest.com>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Server Configuration
PORT=5000
